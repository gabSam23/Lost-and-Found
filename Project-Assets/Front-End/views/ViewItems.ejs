<%- include('layouts/header') %>

<main class="container mt-5">
    <!-- Page title -->
    <section class="row">
        <div class="col-12">
            <h2 class="mb-4 text-center">Lost and Found Storage</h2>
        </div>
    </section>

    <!-- Show a message if one was passed in -->
    <% if (typeof message !== "undefined" && message) { %>
        <div class="alert alert-success">
            <%= message %>
        </div>
    <% } %>

    <!-- Show an error if one was passed in -->
    <% if (typeof error !== "undefined" && error) { %>
        <div class="alert alert-danger">
            <%= error %>
        </div>
    <% } %>

    <!-- Main storage table -->
    <section class="row align-items-start mt-4">
        <div class="col-12">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle shadow-sm">
                    
                    <!-- Table headings -->
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Location</th>
                            <th>Date Logged</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <!-- If there are items, loop through and display each one -->
                        <% if (typeof items !== "undefined" && items.length > 0) { %>
                            <% items.forEach(item => { %>
                                <tr>
                                    <td><%= item.id %></td>

                                    <!-- Show image if available -->
                                    <td>
                                        <% if (item.image) { %>
                                            <img src="<%= item.image %>" alt="Item image" width="80" class="img-thumbnail">
                                        <% } else { %>
                                            <span class="text-muted">No image</span>
                                        <% } %>
                                    </td>

                                    <td><span class="badge bg-secondary"><%= item.category %></span></td>
                                    <td><%= item.description %></td>
                                    <td><i class="bi bi-geo-alt"></i> <%= item.location %></td>
                                    <td><%= item.dateLogged %></td>

                                    <!-- Edit and delete actions -->
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/storage/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                                                Edit
                                            </a>

                                            <form action="/storage/delete/<%= item.id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure?')">
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>

                        <!-- If there are no items, show fallback text -->
                        <% } else { %>
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">No items currently in storage.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</main>

<%- include('layouts/footer') %>