<%- include('layouts/header') %>

<main class="container mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold">Welcome to UR Lost & Found</h1>
            <p class="col-md-8 fs-4">Help connect lost items with their owners. Use the navigation menu to manage the inventory or view active reports.</p>
            <hr class="my-4">
            <div class="d-flex gap-3">
                <a href="/items" class="btn btn-primary btn-lg px-4">View Inventory</a>
                <button class="btn btn-outline-secondary btn-lg px-4">Report an Item</button>
            </div>
        </div>
    </div>

    <div class="row align-items-md-stretch">
        <div class="col-md-6">
            <div class="h-100 p-5 text-white bg-dark rounded-3 shadow">
                <h2>Manage Storage</h2>
                <p>Add new items found on campus or update existing ones in the inventory system.</p>
                <button class="btn btn-outline-light" type="button">Go to Storage</button>
            </div>
        </div>
        <div class="col-md-6">
            <div class="h-100 p-5 bg-light border rounded-3 shadow-sm">
                <h2>User Reports</h2>
                <p>Review reports submitted by students and staff regarding their lost belongings.</p>
                <button class="btn btn-outline-dark" type="button">View Reports</button>
            </div>
        </div>
    </div>
</main>

<%- include('layouts/footer') %>