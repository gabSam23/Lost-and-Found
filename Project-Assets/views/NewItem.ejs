<!-- Shared page header -->
<%- include("layouts/header", { pageTitle, currentUser, bodyClass: "portal-home-body" }) %>

    <% const safeLocationOptions=Array.isArray(locationOptions) ? locationOptions : []; const
        currentLocation=item.location || "" ; const isOtherLocation=currentLocation &&
        !safeLocationOptions.includes(currentLocation); const otherLocationText=isOtherLocation ?
        currentLocation.replace(/^Other\s*-\s*/i, "" ) : "" ; const safeCategoryOptions=Array.isArray(categoryOptions) ?
        categoryOptions : []; const currentCategory=item.category || "" ; const isOtherCategory=currentCategory &&
        !safeCategoryOptions.includes(currentCategory); const otherCategoryText=isOtherCategory ?
        currentCategory.replace(/^Other\s*-\s*/i, "" ) : "" ; %>

        <main class="portal-home-main">
            <div class="container py-4 py-lg-5">
                <div class="row justify-content-center">
                    <div class="col-12 col-md-10 col-lg-8 col-xl-7">

                        <!-- Main form card -->
                        <section class="form-card">

                            <!-- Page title changes depending on create/edit mode -->
                            <h1 class="portal-page-title mb-4">
                                <%= isEdit ? "Edit Lost Item" : "Lost Item Log" %>
                            </h1>

                            <!-- Main item form -->
                            <form action="<%= isEdit ? '/items/' + item.id : '/items' %>" method="POST"
                                enctype="multipart/form-data" class="row g-4">
                                <!-- Location dropdown -->
                                <div class="col-12">
                                    <label for="location" class="form-label">
                                        Location <span class="required-star">*</span>
                                    </label>

                                    <select id="location" name="location" class="form-select" required>
                                        <option value="" disabled <%=!currentLocation ? "selected" : "" %>>
                                            Select location
                                        </option>

                                        <option value="__other__" <%=isOtherLocation ? "selected" : "" %>>
                                            Other
                                        </option>

                                        <% safeLocationOptions.forEach(function(option) { %>
                                            <option value="<%= option %>" <%=currentLocation===option ? "selected" : ""
                                                %>>
                                                <%= option %>
                                            </option>
                                            <% }) %>
                                    </select>

                                    <!-- Show text input only when Other is selected -->
                                    <div id="otherLocationWrapper" class="mt-3"
                                        style="<%= isOtherLocation ? '' : 'display:none;' %>">
                                        <label for="otherLocation" class="form-label">Other Location</label>
                                        <input type="text" id="otherLocation" name="otherLocation" class="form-control"
                                            placeholder="Enter the location" value="<%= otherLocationText %>"
                                            <%=isOtherLocation ? "required" : "" %>
                                        />
                                    </div>
                                </div>

                                <!-- Category dropdown -->
                                <div class="col-12">
                                    <label for="category" class="form-label">
                                        Category <span class="required-star">*</span>
                                    </label>

                                    <select id="category" name="category" class="form-select" required>
                                        <option value="" disabled <%=!currentCategory ? "selected" : "" %>>
                                            Select category
                                        </option>

                                        <option value="__other__" <%=isOtherCategory ? "selected" : "" %>>
                                            Other
                                        </option>

                                        <% safeCategoryOptions.forEach(function(option) { %>
                                            <option value="<%= option %>" <%=currentCategory===option ? "selected" : ""
                                                %>>
                                                <%= option %>
                                            </option>
                                            <% }) %>
                                    </select>

                                    <!-- Show text input only when Other is selected -->
                                    <div id="otherCategoryWrapper" class="mt-3"
                                        style="<%= isOtherCategory ? '' : 'display:none;' %>">
                                        <label for="otherCategory" class="form-label">Other Category</label>
                                        <input type="text" id="otherCategory" name="otherCategory" class="form-control"
                                            placeholder="Enter the category" value="<%= otherCategoryText %>"
                                            <%=isOtherCategory ? "required" : "" %>
                                        />
                                    </div>
                                </div>

                                <!-- Optional image upload -->
                                <div class="col-12">
                                    <label for="itemImage" class="form-label">Upload Image</label>
                                    <input type="file" id="itemImage" name="itemImage" class="form-control"
                                        accept="image/*" />

                                    <% if (isEdit && item.image_url) { %>
                                        <div class="mt-2">
                                            <p class="helper-text mb-1">Current Image:</p>
                                            <div class="item-thumbnail-container">
                                                <img src="<%= item.image_url %>" class="item-thumbnail"
                                                    alt="Item Image" />
                                            </div>
                                        </div>
                                        <% } %>
                                </div>

                                <!-- Description -->
                                <div class="col-12">
                                    <label for="description" class="form-label">
                                        Description <span class="required-star">*</span>
                                    </label>
                                    <textarea id="description" name="description" class="form-control" rows="6"
                                        placeholder="Write item description"
                                        required><%= item.description || '' %></textarea>
                                </div>

                                <!-- Form buttons -->
                                <div class="col-12 d-flex justify-content-end gap-2">
                                    <a href="/items" class="btn btn-outline-secondary">Cancel</a>
                                    <button type="submit" class="btn btn-brand">
                                        <%= isEdit ? "Update Item" : "Submit" %>
                                    </button>
                                </div>
                            </form>
                        </section>
                    </div>
                </div>
            </div>
        </main>

        <script>
            // Toggle the "Other" textboxes on and off
            (function () {
                const locationSelect = document.getElementById("location");
                const otherLocationWrapper = document.getElementById("otherLocationWrapper");
                const otherLocationInput = document.getElementById("otherLocation");

                const categorySelect = document.getElementById("category");
                const otherCategoryWrapper = document.getElementById("otherCategoryWrapper");
                const otherCategoryInput = document.getElementById("otherCategory");

                function toggleOtherLocation() {
                    const usingOther = locationSelect.value === "__other__";
                    otherLocationWrapper.style.display = usingOther ? "" : "none";
                    otherLocationInput.required = usingOther;

                    if (!usingOther) {
                        otherLocationInput.value = "";
                    }
                }

                function toggleOtherCategory() {
                    const usingOther = categorySelect.value === "__other__";
                    otherCategoryWrapper.style.display = usingOther ? "" : "none";
                    otherCategoryInput.required = usingOther;

                    if (!usingOther) {
                        otherCategoryInput.value = "";
                    }
                }

                locationSelect.addEventListener("change", toggleOtherLocation);
                categorySelect.addEventListener("change", toggleOtherCategory);

                toggleOtherLocation();
                toggleOtherCategory();
            })();
        </script>

        <!-- Shared page footer -->
        <%- include("layouts/footer", { footerText: "University of Regina" }) %>