<!-- Include the shared header file from views/layouts/header.ejs.
     pageTitle controls the browser tab title.
     currentUser shows the logged-in user's name in the top bar.
     bodyClass applies page-specific styling to the body. -->
<%- include("layouts/header", { pageTitle, currentUser, bodyClass: "portal-home-body" }) %>

    <!-- Main content area for the page -->
    <main class="portal-home-main">
        <div class="container">

            <!-- Center the form horizontally on the page -->
            <div class="row justify-content-center">

                <!-- Responsive column width for the form card -->
                <div class="col-12 col-md-10 col-lg-7 col-xl-6">

                    <!-- Card that contains the new/edit item form -->
                    <section class="form-card">

                        <!-- Page title changes depending on whether the user is editing or adding an item -->
                        <h1 class="portal-page-title mb-4">
                            <%= isEdit ? 'Edit Lost Item' : 'Lost Item Log' %>
                        </h1>

                        <!-- Form action changes based on mode:
                         - Edit mode submits to /items/:id
                         - New item mode submits to /items -->
                        <form action="<%= isEdit ? '/items/' + item.id : '/items' %>" method="POST" enctype="multipart/form-data" class="row g-4">

                            <!-- Location dropdown field -->
                            <div class="col-12">
                                <label for="location" class="form-label">Location</label>

                                <select id="location" name="location" class="form-select" required>
                                    <!-- Default placeholder option -->
                                    <option value="" disabled <%=!item.location ? 'selected' : '' %>>
                                        Select location
                                    </option>

                                    <!-- Loop through each location option and mark it as selected if it matches the item's current value -->
                                    <% ['Classroom Building', 'Riddell Centre' , 'Library' , 'Residence' , 'Other'
                                        ].forEach(function(option) { %>
                                        <option value="<%= option %>" <%=item.location===option ? 'selected' : '' %>>
                                            <%= option %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <!-- Category dropdown field -->
                            <div class="col-12">
                                <label for="category" class="form-label">Category</label>

                                <select id="category" name="category" class="form-select" required>
                                    <!-- Default placeholder option -->
                                    <option value="" disabled <%=!item.category ? 'selected' : '' %>>
                                        Select category
                                    </option>

                                    <!-- Loop through each category option and mark it as selected if it matches the item's current value -->
                                    <% ['Accessories', 'Electronics' , 'Identification' , 'Clothing' , 'Other'
                                        ].forEach(function(option) { %>
                                        <option value="<%= option %>" <%=item.category===option ? 'selected' : '' %>>
                                            <%= option %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>

                            <!-- File input for uploading item images -->
                            <div class="col-12">
                                <label for="itemImage" class="form-label">Upload Image</label>
                                <input type="file" id="itemImage" name="itemImage" class="form-control" accept="image/*" />
                                <% if (isEdit && item.image_url) { %>
                                    <div class="mt-2">
                                        <p class="helper-text mb-1">Current Image:</p>
                                        <div class="item-thumbnail-container">
                                            <img src="<%= item.image_url %>" class="item-thumbnail" alt="Item Image" />
                                        </div>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Description text area for the item -->
                            <div class="col-12">
                                <label for="description" class="form-label">Description</label>
                                <textarea id="description" name="description" class="form-control" rows="6"
                                    placeholder="Write item description"
                                    required><%= item.description || '' %></textarea>
                            </div>

                            <!-- Action buttons -->
                            <div class="col-12 d-flex justify-content-end gap-2">

                                <!-- Cancel button returns the user to the inventory page without saving -->
                                <a href="/items" class="btn btn-outline-secondary">Cancel</a>

                                <!-- Submit button text changes depending on whether this is edit mode or create mode -->
                                <button type="submit" class="btn btn-brand">
                                    <%= isEdit ? 'Update Item' : 'Submit' %>
                                </button>
                            </div>
                        </form>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <!-- Include the shared footer file from views/layouts/footer.ejs -->
    <%- include("layouts/footer", { footerText: "University of Regina" }) %>