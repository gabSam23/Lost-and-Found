<!-- Include the shared header layout from views/layouts/header.ejs.
     pageTitle sets the browser tab title.
     currentUser displays the logged-in user's name in the top bar.
     bodyClass applies page-specific styling to the body. -->
<%- include("layouts/header", { pageTitle, currentUser, bodyClass: "portal-home-body" }) %>

    <!-- Main content area for the reports list page -->
    <main class="portal-home-main">
        <div class="container py-4 py-lg-5">

            <!-- Page heading section -->
            <section class="portal-page-header mb-4">
                <h1 class="portal-page-title">UR Lost &amp; Found</h1>
                <p class="page-description">
                    Review submitted lost item reports and manage report records.
                </p>
            </section>

            <!-- Card container that holds the report list -->
            <div class="list-card">

                <!-- Toolbar/header area above the table -->
                <div
                    class="list-toolbar d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">

                    <!-- Left side: section title and description -->
                    <div>
                        <h2 class="h5 mb-1">Lost Item Reports</h2>
                        <p class="text-muted mb-0">
                            View, edit, and delete submitted lost item reports.
                        </p>
                    </div>

                    <!-- Right side: badge showing number of reports -->
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge text-bg-light border px-3 py-2">
                            <%= reports.length %> record(s)
                        </span>
                    </div>
                </div>

                <!-- If there are no reports, show an empty-state message -->
                <% if (reports.length===0) { %>
                    <div class="empty-state">No reports have been submitted yet.</div>

                    <!-- Otherwise, show the reports table -->
                    <% } else { %>
                        <div class="table-responsive p-3">

                            <!-- Bootstrap table used to display all reports -->
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <!-- Table column headings -->
                                        <th>Report ID</th>
                                        <th>Item</th>
                                        <th>Category</th>
                                        <th>Reporter</th>
                                        <th>Last Known Location</th>
                                        <th>Date Lost</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <!-- Loop through each report in the reports array -->
                                    <% reports.forEach(function(report) { %>
                                        <tr>

                                            <!-- Unique report ID -->
                                            <td>
                                                <%= report.id %>
                                            </td>

                                            <!-- Name of the missing item -->
                                            <td>
                                                <%= report.missing_item_name %>
                                            </td>

                                            <!-- Report category -->
                                            <td>
                                                <%= report.category %>
                                            </td>

                                            <!-- Reporter details -->
                                            <td>
                                                <!-- Reporter name in bold -->
                                                <strong>
                                                    <%= report.reporter_name %>
                                                </strong><br />

                                                <!-- Reporter email -->
                                                <small>
                                                    <%= report.reporter_email %>
                                                </small>

                                                <!-- Only show phone number if one exists -->
                                                <% if (report.phone_number) { %>
                                                    <br />
                                                    <small>
                                                        <%= report.phone_number %>
                                                    </small>
                                                    <% } %>
                                            </td>

                                            <!-- Last known location of the missing item -->
                                            <td>
                                                <%= report.last_known_location %>
                                            </td>

                                            <!-- Date the item was lost -->
                                            <td>
                                                <%= new Date(report.date_lost).toLocaleDateString() %>
                                            </td>

                                            <!-- Current report status shown as a badge -->
                                            <td>
                                                <span class="status-badge status-<%= report.status.toLowerCase() %>">
                                                    <%= report.status %>
                                                </span>
                                            </td>

                                            <!-- Action buttons -->
                                            <td class="actions-cell">
                                                <div class="table-actions d-flex gap-2">

                                                    <!-- Edit button triggers a modal -->
                                                    <button type="button" 
                                                            class="btn btn-outline-primary btn-sm"
                                                            data-bs-toggle="modal" 
                                                            data-bs-target="#editReportModal"
                                                            data-id="<%= report.id %>"
                                                            data-name="<%= report.missing_item_name %>"
                                                            data-category="<%= report.category %>"
                                                            data-location="<%= report.last_known_location %>"
                                                            data-description="<%= report.description %>"
                                                            data-status="<%= report.status %>"
                                                            data-reporter-name="<%= report.reporter_name %>"
                                                            data-reporter-email="<%= report.reporter_email %>"
                                                            data-reporter-phone="<%= report.phone_number %>">
                                                        Edit
                                                    </button>

                                                    <!-- Delete form sends a POST request to delete this report -->
                                                    <form action="/reports/<%= report.id %>/delete" method="POST"
                                                        class="m-0">

                                                        <!-- Confirmation popup appears before deleting -->
                                                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                                            onclick="return confirm('Are you sure you want to delete this report?');">
                                                            Delete
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination Controls -->
                        <% if (totalPages > 1) { %>
                            <div class="pagination-container">
                                <nav aria-label="Page navigation">
                                    <ul class="pagination">
                                        <% for(let i = 1; i <= totalPages; i++) { %>
                                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                <a class="page-link" href="/reports?page=<%= i %>&user=<%= currentUser %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                        <% } %>
                                    </ul>
                                </nav>
                            </div>
                        <% } %>

                        <% } %>
            </div>
        </div>
    </main>

    <!-- Include the shared footer layout from views/layouts/footer.ejs.
     footerText changes the text shown on the right side of the footer. -->
    <%- include("layouts/footer", { footerText: "University of Regina interface prototype" }) %>

    <!-- Edit Report Modal -->
    <div class="modal fade" id="editReportModal" tabindex="-1" aria-labelledby="editReportModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editReportModalLabel">Edit Report Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="editReportForm" method="POST" action="">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="modal-item-name" class="form-label">Item Name</label>
                                <input type="text" id="modal-item-name" name="itemName" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label for="modal-category" class="form-label">Category</label>
                                <select id="modal-category" name="category" class="form-select" required>
                                    <% ['Accessories', 'Electronics' , 'Identification' , 'Clothing' , 'Other'].forEach(function(opt) { %>
                                        <option value="<%= opt %>"><%= opt %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="modal-location" class="form-label">Last Known Location</label>
                                <input type="text" id="modal-location" name="lostLocation" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label for="modal-status" class="form-label">Report Status</label>
                                <select id="modal-status" name="status" class="form-select">
                                    <option value="Open">Open</option>
                                    <option value="Resolved">Resolved</option>
                                    <option value="Closed">Closed</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label for="modal-description" class="form-label">Description</label>
                                <textarea id="modal-description" name="description" class="form-control" rows="2" required></textarea>
                            </div>
                        </div>

                        <hr>
                        <div class="mt-3">
                            <h6 class="fw-bold"><i class="bi bi-person me-2"></i>Reporter Info</h6>
                            <div class="p-2 bg-light rounded small">
                                <div id="modal-reporter-display"></div>
                            </div>
                        </div>

                        <hr>
                        <!-- Potential Matches Section -->
                        <div class="mt-3">
                            <h6 class="fw-bold"><i class="bi bi-magic me-2"></i>Potential Matches (Inventory)</h6>
                            <div id="report-matches-container" class="list-group list-group-flush border rounded" style="max-height: 200px; overflow-y: auto;">
                                <div class="p-3 text-center text-muted small">Loading potential matches...</div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-brand">Update Report</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const editReportModal = document.getElementById('editReportModal');
            if (editReportModal) {
                editReportModal.addEventListener('show.bs.modal', function(event) {
                    const button = event.relatedTarget;
                    const id = button.getAttribute('data-id');
                    
                    // Update form action
                    document.getElementById('editReportForm').action = '/reports/' + id;

                    // Populate fields
                    document.getElementById('modal-item-name').value = button.getAttribute('data-name');
                    document.getElementById('modal-category').value = button.getAttribute('data-category');
                    document.getElementById('modal-location').value = button.getAttribute('data-location');
                    document.getElementById('modal-status').value = button.getAttribute('data-status');
                    document.getElementById('modal-description').value = button.getAttribute('data-description');

                    // Populate Reporter Info
                    const repName = button.getAttribute('data-reporter-name');
                    const repEmail = button.getAttribute('data-reporter-email');
                    const repPhone = button.getAttribute('data-reporter-phone');
                    document.getElementById('modal-reporter-display').innerHTML = `
                        <strong>Name:</strong> ${repName}<br>
                        <strong>Email:</strong> ${repEmail}<br>
                        <strong>Phone:</strong> ${repPhone || 'N/A'}
                    `;

                    // Fetch Matches
                    const matchesContainer = document.getElementById('report-matches-container');
                    matchesContainer.innerHTML = '<div class="p-3 text-center text-muted small">Searching inventory...</div>';
                    
                    fetch(`/api/matches/report/${id}`)
                        .then(res => res.json())
                        .then(matches => {
                            if (matches.length === 0) {
                                matchesContainer.innerHTML = '<div class="p-3 text-center text-muted small">No potential inventory matches found.</div>';
                            } else {
                                matchesContainer.innerHTML = matches.map(m => `
                                    <div class="list-group-item list-group-item-action p-2">
                                        <div class="d-flex align-items-center gap-2">
                                            ${m.image_url ? `<img src="${m.image_url}" class="rounded" style="width: 40px; height: 40px; object-fit: cover;">` : '<div class="bg-light rounded text-muted extra-small d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-size: 0.5rem;">No Img</div>'}
                                            <div class="flex-grow-1">
                                                <div class="d-flex w-100 justify-content-between">
                                                    <h6 class="mb-0 text-primary small fw-bold">ID: ${m.id} - ${m.category}</h6>
                                                    <span class="badge bg-info text-dark" style="font-size: 0.65rem;">${m.score}% Match</span>
                                                </div>
                                                <p class="mb-0 extra-small text-muted" style="font-size: 0.75rem;">${m.description.substring(0, 50)}...</p>
                                                <div class="extra-small text-dark" style="font-size: 0.7rem;">
                                                    <i class="bi bi-geo-alt me-1"></i>${m.location}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                `).join('');
                            }
                        })
                        .catch(err => {
                            matchesContainer.innerHTML = '<div class="p-3 text-center text-danger small">Error loading matches.</div>';
                        });
                });
            }
        });
    </script>