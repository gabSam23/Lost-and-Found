<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Character encoding for proper text display -->
  <meta charset="UTF-8" />

  <!-- Makes Internet Explorer use the newest rendering mode -->
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Makes the layout responsive on different screen sizes -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Dynamic page title passed in from the page that includes this layout -->
  <title><%= pageTitle %></title>

  <!-- Bootstrap CSS for layout, forms, buttons, spacing, and components -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
    crossorigin="anonymous"
  />

  <!-- Bootstrap Icons stylesheet for icons used in the header -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  />

  <!-- Custom stylesheet from public/css/style.css -->
  <link rel="stylesheet" href="/css/style.css" />
</head>

<!-- The body class is dynamic:
     - uses bodyClass if passed in
     - otherwise defaults to 'portal-home-body' -->
<body class="<%= bodyClass || 'portal-home-body' %>">

  <!-- Top navigation bar -->
  <header class="portal-topbar">

    <!-- Left side of the top bar -->
    <div class="portal-topbar-left">

      <!-- Button/icon that links back to the home page -->
      <a href="/home" class="portal-icon-btn" aria-label="Open menu">
        <i class="bi bi-grid-3x3-gap-fill"></i>
      </a>

      <!-- University logo, also links back to the home page -->
      <a href="/home" class="portal-brand" aria-label="University of Regina Home">
        <img
          src="/images/UR_Logo_Primary_Reverse_White.png"
          alt="University of Regina logo"
          class="portal-brand-logo"
        />
      </a>
    </div>

    <!-- Right side of the top bar -->
    <div class="portal-topbar-right">

      <!-- Settings icon button
           Right now this is only visual and does not have any functionality -->
      <button class="portal-icon-btn" type="button" aria-label="Settings">
        <i class="bi bi-gear-fill"></i>
      </button>

      <!-- User dropdown menu -->
      <div class="dropdown portal-user-dropdown">

        <!-- Button that opens the account dropdown menu -->
        <button
          class="portal-user-chip portal-user-chip-toggle"
          type="button"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          aria-label="Open account menu"
        >

          <!-- User avatar icon -->
          <span class="portal-user-avatar" aria-hidden="true">
            <i class="bi bi-person-fill"></i>
          </span>

          <!-- Show the logged-in user's name, or 'Account' if none is provided -->
          <span class="portal-user-name"><%= currentUser || 'Account' %></span>
        </button>

        <!-- Dropdown menu content -->
        <ul class="dropdown-menu dropdown-menu-end portal-signout-menu">

          <!-- Sign out link sends the user to the /logout route -->
          <li><a class="dropdown-item portal-signout-link" href="/logout">Sign Out</a></li>
        </ul>
      </div>
    </div>
  </header>