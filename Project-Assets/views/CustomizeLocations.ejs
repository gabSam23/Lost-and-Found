<!-- Shared page header -->
<%- include("layouts/header", { pageTitle, currentUser, bodyClass: "portal-home-body" }) %>

    <main class="portal-home-main">
        <div class="container py-4 py-lg-5">

            <!-- Page title -->
            <section class="portal-page-header mb-4">
                <h1 class="portal-page-title">Customize Locations</h1>
                <p class="page-description">
                    Manage the saved location options used in item logging and lost item reports.
                </p>
            </section>

            <!-- Main content card -->
            <section class="list-card p-3">

                <!-- Section heading -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
                    <div>
                        <h2 class="h5 mb-1">Saved Locations</h2>
                        <p class="text-muted mb-0">
                            Add, edit, or remove location options.
                        </p>
                    </div>
                </div>

                <!-- Form for adding a new location -->
                <form action="/admin/locations/add" method="POST" class="row g-2 mb-4">
                    <div class="col-md-8">
                        <input type="text" name="newLocation" class="form-control" placeholder="Enter a new location"
                            required />
                    </div>

                    <div class="col-md-4 d-grid">
                        <button type="submit" class="btn btn-brand">Add Location</button>
                    </div>
                </form>

                <!-- Empty state if no locations exist -->
                <% if (!locationOptions || locationOptions.length===0) { %>
                    <div class="empty-state">No saved locations yet.</div>
                    <% } else { %>

                        <!-- Table of saved locations -->
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Location</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    <% locationOptions.forEach(function(option) { %>
                                        <tr>
                                            <td>
                                                <%= option %>
                                            </td>
                                            <td>
                                                <div class="d-flex justify-content-end gap-2">
                                                    <button type="button" class="btn btn-outline-secondary btn-sm"
                                                        onclick="editLocationOption('<%- JSON.stringify(option).slice(1, -1) %>')">
                                                        Edit
                                                    </button>

                                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                                        onclick="deleteLocationOption('<%- JSON.stringify(option).slice(1, -1) %>')">
                                                        Delete
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>

            </section>
        </div>
    </main>

    <!-- Hidden form used to edit an existing location -->
    <form id="editLocationOptionForm" method="POST" action="/options/location/edit" class="d-none">
        <input type="hidden" name="oldValue" id="editLocationOldValue">
        <input type="hidden" name="newValue" id="editLocationNewValue">
        <input type="hidden" name="redirectTo" value="/admin/locations">
    </form>

    <!-- Hidden form used to delete an existing location -->
    <form id="deleteLocationOptionForm" method="POST" action="/options/location/delete" class="d-none">
        <input type="hidden" name="value" id="deleteLocationValue">
        <input type="hidden" name="redirectTo" value="/admin/locations">
    </form>

    <script>
        // Opens a prompt so the user can rename a saved location
        function editLocationOption(oldValue) {
            const newValue = window.prompt("Edit location", oldValue);

            // Stop if the user cancels or leaves it empty
            if (!newValue || !newValue.trim()) {
                return;
            }

            // Fill the hidden form fields
            document.getElementById("editLocationOldValue").value = oldValue;
            document.getElementById("editLocationNewValue").value = newValue.trim();

            // Submit the edit form
            document.getElementById("editLocationOptionForm").submit();
        }

        // Asks for confirmation, then deletes the selected location
        function deleteLocationOption(value) {
            if (!window.confirm("Delete this location?")) {
                return;
            }

            // Fill the hidden delete form field
            document.getElementById("deleteLocationValue").value = value;

            // Submit the delete form
            document.getElementById("deleteLocationOptionForm").submit();
        }
    </script>

    <!-- Shared page footer -->
    <%- include("layouts/footer", { footerText: "University of Regina" }) %>